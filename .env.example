# Supabase (auth + sync cloud)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Sign-In (affiche « ScanPlay » au lieu de supabase.co) — voir GOOGLE_OAUTH_SETUP.md
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Analyse IA des fiches (Edge Function analyze-sheet)
# OpenAI = secrets Supabase (PAS dans ce fichier) :
#   supabase secrets set OPENAI_API_KEY=sk-...
# Scan photo (vision) — défaut gpt-4.1 dans le code ; pour forcer en prod :
#   supabase secrets set OPENAI_SCAN_MODEL=gpt-4.1
#   supabase functions deploy analyze-sheet
# Traçabilité SQL : supabase/patch-gpt-4.1-scan-model.sql
# Synthèse texte (generate-synthesis) — optionnel, défaut gpt-4o-mini :
#   supabase secrets set OPENAI_MODEL=gpt-4o-mini
# Désactiver l'IA côté client : VITE_AI_SCAN=0
VITE_AI_SCAN=1

# Activer Stripe Checkout (1 = paiement réel, 0 = simulation locale)
VITE_STRIPE_CHECKOUT=0

# --- Variables SERVEUR uniquement (Vercel → Settings → Environment Variables) ---
# Ne jamais mettre ces clés dans le code client ni dans Cursor .env si tu commites.

# Stripe — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_...          # ou sk_live_... en production
# STRIPE_WEBHOOK_SECRET=whsec_...        # Webhook endpoint → /api/stripe-webhook

# Price IDs (Products → chaque prix récurrent → copier price_...)
# STRIPE_PRICE_PLUS_MONTHLY=price_...
# STRIPE_PRICE_PLUS_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...

# URL publique du site (obligatoire pour les redirections Checkout)
# APP_URL=https://scanplay.org

# Supabase service role — Settings → API → service_role (webhook met à jour le plan)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Optionnel si déjà en VITE_* : SUPABASE_URL= SUPABASE_ANON_KEY=
# 1) Créer un compte AdSense et ajouter le site https://scanplay.org
# 2) Créer des blocs d'annonces → récupérer ca-pub-… et les numéros de slot
# 3) Copier public/ads.txt.example vers public/ads.txt et remplacer pub-…
# 4) Variables Vercel : Project → Settings → Environment Variables
# 5) Redéployer → Google vérifie scanplay.org via le script injecté dans <head>
#    (méthode « AdSense code snippet » — pas besoin de coller le code à la main)
# Option meta tag : VITE_ADSENSE_VERIFY_META=ca-pub-… (si Google propose cette méthode)
VITE_ADSENSE_ENABLED=1
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT_SHOP=0000000000
VITE_ADSENSE_SLOT_REWARD=0000000000

# Reconnaissance vocale serveur (optionnel, gratuit via Groq Whisper)
# 1) Créer un compte sur https://console.groq.com → API Keys
# 2) Vercel → GROQ_API_KEY=gsk_...
# Activer la transcription serveur Groq pour le jeu oral (nécessite GROQ_API_KEY sur Vercel)
# VITE_SPEECH_SERVER=1
# GROQ_API_KEY=gsk_...   (serveur uniquement, pas VITE_)

# Resend — signalements utilisateur (api/report-error), pas les emails d'inscription
# RESEND_API_KEY=re_...
# (Emails auth : clé re_... dans Supabase → Authentication → SMTP Settings)
